Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Created", " ", "by", " ", "Gene", " ", "Kopp"}], ",", " ", 
    RowBox[{"Aug", " ", "2025"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Functions", " ", "to", " ", "convert", " ", "tuples", " ", "of", " ", 
     "inexact", " ", "numbers", " ", "to", " ", "exact", " ", "numbers"}], ",",
     " ", 
    RowBox[{
    "assuming", " ", "they", " ", "are", " ", "Galois", " ", "conjugate", " ",
      "over", " ", "a", " ", "small", " ", "field"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Includes", " ", "exactification", " ", "of", " ", "triple", " ", 
    "products"}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.965477738290395*^9, 3.965477873164833*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"ebdcd174-1376-46bb-9006-ae5e88c8fb49"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Standard", " ", "shortcuts", " ", "for", " ", "displaying", " ", 
    "matrices"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"mf", "=", "MatrixForm"}], ";", 
    RowBox[{"mp", "=", "MatrixPlot"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Position", " ", "of", " ", "the", " ", "minimum", " ", "element", " ", 
     "of", " ", "a", " ", "list", " ", "of", " ", "distinct", " ", "real", " ",
      "numbers"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"positionSmallest", "[", "l_", "]"}], ":=", 
     RowBox[{
      RowBox[{"FirstPosition", "[", 
       RowBox[{"l", ",", 
        RowBox[{"Min", "[", "l", "]"}]}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Exactification", " ", "using", " ", "elementary", " ", "symmetric", " ", 
     "polynomials", " ", "and", " ", "RootApproximant"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "If", " ", "optional", " ", "variable", " ", "ratcoeffs", " ", "is", " ",
       "set", " ", "to", " ", "True"}], ",", " ", 
     RowBox[{
     "instead", " ", "use", " ", "Rationalize", " ", "on", " ", 
      "coefficeints"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"exactifyTuple", "[", 
      RowBox[{"\[Alpha]_", ",", 
       RowBox[{"ratcoeffs_", ":", "False"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"deg", ",", "ESP", ",", "exactESP", ",", "f", ",", "roots"}], 
        "}"}], ",", 
       RowBox[{
        RowBox[{"deg", "=", 
         RowBox[{"Length", "[", "\[Alpha]", "]"}]}], ";", 
        RowBox[{"ESP", "=", 
         RowBox[{"CoefficientList", "[", 
          RowBox[{
           RowBox[{"Expand", "[", 
            RowBox[{"Times", "@@", 
             RowBox[{"(", 
              RowBox[{"X", "-", "\[Alpha]"}], ")"}]}], "]"}], ",", "X"}], 
          "]"}]}], ";", 
        RowBox[{"If", "[", 
         RowBox[{"ratcoeffs", ",", 
          RowBox[{"exactESP", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"Rationalize", "[", 
              RowBox[{"#", ",", 
               RowBox[{"10", "^", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"-", "0.75"}], 
                  RowBox[{"Precision", "[", 
                   RowBox[{"\[Alpha]", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ")"}]}]}], "]"}],
              "&"}], "/@", "ESP"}]}], ",", 
          RowBox[{"exactESP", "=", 
           RowBox[{"RootApproximant", "/@", "ESP"}]}]}], "]"}], ";", 
        RowBox[{"f", "=", 
         RowBox[{
          RowBox[{"Plus", "@@", 
           RowBox[{"(", 
            RowBox[{"exactESP", ".", 
             RowBox[{"#", "^", 
              RowBox[{"Range", "[", 
               RowBox[{"0", ",", "deg"}], "]"}]}]}], ")"}]}], "&"}]}], ";", 
        RowBox[{"roots", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"RootReduce", "[", 
            RowBox[{"Root", "[", 
             RowBox[{"f", ",", "j"}], "]"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "1", ",", "deg"}], "}"}]}], "]"}]}], ";", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"roots", "[", 
           RowBox[{"[", 
            RowBox[{"positionSmallest", "[", 
             RowBox[{"Abs", "/@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"\[Alpha]", "[", 
                 RowBox[{"[", "j", "]"}], "]"}], "-", "roots"}], ")"}]}], 
             "]"}], "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "deg"}], "}"}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Converts", " ", "an", " ", "array", " ", "to", " ", "a", " ", "list", " ",
       "of", " ", "distinct", " ", "elements"}], " ", "->", " ", 
     RowBox[{"array", " ", "positions"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"arrayPositionMap", "[", 
      RowBox[{"l_", ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"elts", ",", "positions", ",", "level"}], "}"}], ",", 
       RowBox[{
        RowBox[{"elts", "=", 
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "l", "]"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"#1", "-", "#2"}], "]"}], "<", "tolerence"}], "&"}]}], 
          "]"}]}], ";", 
        RowBox[{"level", "=", 
         RowBox[{"Length", "[", 
          RowBox[{"Dimensions", "[", "l", "]"}], "]"}]}], ";", 
        RowBox[{"positions", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Position", "[", 
            RowBox[{"l", ",", 
             RowBox[{"_", "?", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"Abs", "[", 
                  RowBox[{"#", "-", 
                   RowBox[{"elts", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "]"}], "<", 
                 "tolerence"}], "&"}], ")"}]}], ",", "level"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "1", ",", 
             RowBox[{"Length", "[", "elts", "]"}]}], "}"}]}], "]"}]}], ";", 
        RowBox[{"Thread", "[", 
         RowBox[{"positions", "->", "elts"}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Covert", " ", "an", " ", "array", " ", "position", " ", "map", " ", "to",
      " ", "a", " ", "standard", " ", "array"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"arrayFromPositionMap", "[", "PM_", "]"}], ":=", 
    RowBox[{"Normal", "[", 
     RowBox[{"SparseArray", "[", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Thread", "/@", "PM"}], ",", "1"}], "]"}], "]"}], "]"}]}], ";",
    "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Exactify", " ", "a", " ", "position", " ", "map", " ", "of", " ", 
      "triple", " ", "products"}], ",", " ", 
     RowBox[{
     "taking", " ", "advantage", " ", "of", " ", "possible", " ", "Galois", " ",
       "conjugates"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"exactifyTPPM", "[", "TPPM_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"elts", ",", "positions", ",", "exactelts"}], "}"}], ",", 
      RowBox[{
       RowBox[{"elts", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", 
            RowBox[{"-", "1"}], "]"}], "]"}], "&"}], "/@", "TPPM"}]}], ";", 
       RowBox[{"positions", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "&"}], "/@", "TPPM"}]}], ";", 
       RowBox[{"exactelts", "=", 
        RowBox[{"exactifyTuple", "[", "elts", "]"}]}], ";", 
       RowBox[{"Thread", "[", 
        RowBox[{"positions", "->", "exactelts"}], "]"}]}]}], "]"}]}], ";", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Exactify", " ", "a", " ", "triple", " ", "product", " ", "tensor"}], ",",
      " ", 
     RowBox[{
     "taking", " ", "advantage", " ", "of", " ", "possible", " ", "Galois", " ",
       "conjugates"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"exactifyTP", "[", 
      RowBox[{"T_", ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"arrayFromPositionMap", "[", 
      RowBox[{"exactifyTPPM", "[", 
       RowBox[{"arrayPositionMap", "[", 
        RowBox[{"T", ",", "tolerence"}], "]"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Exactify", " ", "a", " ", "position", " ", "map", " ", "of", " ", 
     "triple", " ", "products", " ", "naively", " ", "using", " ", 
     "RootApproximant"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"exactifyTPPMalt", "[", "TPPM_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"elts", ",", "positions", ",", "exactelts"}], "}"}], ",", 
       RowBox[{
        RowBox[{"elts", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}], "&"}], "/@", "TPPM"}]}], ";", 
        RowBox[{"positions", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "&"}], "/@", "TPPM"}]}], ";", 
        RowBox[{"exactelts", "=", 
         RowBox[{"RootApproximant", "/@", "elts"}]}], ";", 
        RowBox[{"Thread", "[", 
         RowBox[{"positions", "->", "exactelts"}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Exactify", " ", "a", " ", "triple", " ", "product", " ", "tensor", " ", 
     "naively", " ", "using", " ", "RootApproximant"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"exactifyTPalt", "[", 
      RowBox[{"T_", ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"arrayFromPositionMap", "[", 
      RowBox[{"exactifyTPPMalt", "[", 
       RowBox[{"arrayPositionMap", "[", 
        RowBox[{"T", ",", "tolerence"}], "]"}], "]"}], "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.965477885413653*^9, 3.9654780389536057`*^9}, {
